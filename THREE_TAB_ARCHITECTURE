## 3. Routing Architecture

### Route Structure

```
/insights                          → Redirect to /insights/chat
/insights/chat                     → New conversation (no thread selected)
/insights/chat/:threadId           → Specific thread view
/insights/chat/:threadId?answer=X&tab=Y  → Deep link to answer + tab
/insights/dashboard                → Pinned charts dashboard
```

### Router Configuration

```js
// src/routes/InsightsRoutes.js
import { Routes, Route, Navigate } from 'react-router-dom';
import { InsightsLayout } from '@/layouts/InsightsLayout';
import { ChatView } from '@/views/ChatView';
import { DashboardView } from '@/views/DashboardView';

export const InsightsRoutes = ({ 
  basePath = '/insights' 
}) => {
  return (
    <Routes>
      <Route path="/" element={<InsightsLayout />}>
        {/* Default redirect */}
        <Route index element={<Navigate to="chat" replace />} />
        
        {/* Chat routes */}
        <Route path="chat" element={<ChatView />} />
        <Route path="chat/:threadId" element={<ChatView />} />
        
        {/* Dashboard route */}
        <Route path="dashboard" element={<DashboardView />} />
        
        {/* Catch-all redirect */}
        <Route path="*" element={<Navigate to="chat" replace />} />
      </Route>
    </Routes>
  );
};
```

