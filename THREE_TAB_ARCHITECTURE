          return (
            <Card key={chart.id} className={styles.chartCard}>
              {/* Header */}
              <div className={styles.cardHeader}>
                <div className={styles.cardTitle}>
                  <Text styleAs="label" color="secondary">
                    {chart.threadTitle}
                  </Text>
                  <Text>{chart.question}</Text>
                </div>
                
                <div className={styles.cardActions}>
                  <Button 
                    variant="secondary" 
                    onClick={function() { handleGoToSource(chart); }}
                  >
                    <ExternalLinkIcon />
                  </Button>
                  <Button 
                    variant="secondary" 
                    onClick={function() { handleUnpin(chart); }}
                  >
                    <DeleteIcon />
                  </Button>
                </div>
              </div>

              {/* Chart */}
              <div className={styles.chartContainer}>
                <ReactECharts
                  option={chart.chartOption}
                  style={{ height: '250px', width: '100%' }}
                  opts={{ renderer: 'canvas' }}
                />
              </div>

              {/* Footer */}
              <div className={styles.cardFooter}>
                <Text color="secondary" styleAs="label">
                  Pinned {new Date(chart.createdAt).toLocaleDateString()}
                </Text>
              </div>
            </Card>
          );
        })}
      </div>
    </div>
  );
}

export default DashboardView;
