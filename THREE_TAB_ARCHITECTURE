### Conversation Context

```js
// src/contexts/ConversationContext.js
import React, { createContext, useContext, useCallback } from 'react';
import { useLocalStorageState } from '@/hooks/useLocalStorageState';

const ConversationContext = createContext(null);

export const ConversationProvider = ({ 
  children 
}) => {
  const [threads, setThreads] = useLocalStorageState('insights-threads', []);
  const [activeThreadId, setActiveThreadId] = useLocalStorageState(
    'insights-active-thread', 
    null
  );

  const activeThread = threads.find(t => t.id === activeThreadId) || null;

  const createThread = useCallback(() => {
    const newThread: Thread = {
      id: crypto.randomUUID(),
      title: 'New Conversation',
      messages: [],
      createdAt: new Date(),
      updatedAt: new Date(),
    };
    setThreads(prev => [newThread, ...prev]);
    setActiveThreadId(newThread.id);
    return newThread.id;
  }, [setThreads, setActiveThreadId]);

  const selectThread = useCallback((threadId) => {
    setActiveThreadId(threadId);
  }, [setActiveThreadId]);

  const deleteThread = useCallback((threadId) => {
    setThreads(prev => prev.filter(t => t.id !== threadId));
    if (activeThreadId === threadId) {
      setActiveThreadId(null);
    }
  }, [setThreads, activeThreadId, setActiveThreadId]);

  const addMessage = useCallback((
    threadId, 
    message
  ) => {
    const messageId = crypto.randomUUID();
    const newMessage: Message = {
      ...message,
      id: messageId,
      timestamp: new Date(),
    };

    setThreads(prev => prev.map(thread => {
      if (thread.id !== threadId) return thread;
      
      // Update title from first user message
      const title = thread.messages.length === 0 && message.role === 'user'
        ? message.content.slice(0, 50) + (message.content.length > 50 ? '...' : '')
        : thread.title;

      return {
        ...thread,
        title,
        messages: [...thread.messages, newMessage],
        updatedAt: new Date(),
      };
    }));

    return messageId;
  }, [setThreads]);

  const updateMessage = useCallback((
    threadId, 
    messageId, 
    updates
  ) => {
    setThreads(prev => prev.map(thread => {
      if (thread.id !== threadId) return thread;
      return {
        ...thread,
        messages: thread.messages.map(msg => 
          msg.id === messageId ? { ...msg, ...updates } : msg
        ),
        updatedAt: new Date(),
      };
    }));
  }, [setThreads]);

  return (
    <ConversationContext.Provider value={{
      threads,
      activeThreadId,
      activeThread,
      createThread,
      selectThread,
      deleteThread,
      addMessage,
      updateMessage,
    }}>
      {children}
    </ConversationContext.Provider>
  );
};

export const useConversation = () => {
  const context = useContext(ConversationContext);
  if (!context) {
    throw new Error('useConversation must be used within ConversationProvider');
  }
  return context;
};
```

### Chart Context (for Pinning)

```js
// src/contexts/ChartContext.js
import React, { createContext, useContext, useCallback } from 'react';
import { useLocalStorageState } from '@/hooks/useLocalStorageState';
import type { EChartsOption } from 'echarts';


const ChartContext = createContext(null);

export const ChartProvider = ({ 
  children 
}) => {
  const [pinnedCharts, setPinnedCharts] = useLocalStorageState(
    'insights-pinned-charts', 
    []
  );

  const isPinned = useCallback((chartId) => {
    return pinnedCharts.some(c => c.id === chartId || c.messageId === chartId);
  }, [pinnedCharts]);

  const pinChart = useCallback((chart) => {
    const newChart: PinnedChart = {
      ...chart,
      id: crypto.randomUUID(),
      pinnedAt: new Date(),
    };
    setPinnedCharts(prev => [...prev, newChart]);
  }, [setPinnedCharts]);

  const unpinChart = useCallback((chartId) => {
    setPinnedCharts(prev => prev.filter(c => c.id !== chartId));
  }, [setPinnedCharts]);

  const updatePinnedChart = useCallback((
    chartId, 
    updates
  ) => {
    setPinnedCharts(prev => prev.map(chart => 
      chart.id === chartId ? { ...chart, ...updates } : chart
    ));
  }, [setPinnedCharts]);

  const reorderCharts = useCallback((startIndex, endIndex) => {
    setPinnedCharts(prev => {
      const result = Array.from(prev);
      const [removed] = result.splice(startIndex, 1);
      result.splice(endIndex, 0, removed);
      return result;
    });
  }, [setPinnedCharts]);

  return (
    <ChartContext.Provider value={{
      pinnedCharts,
      isPinned,
      pinChart,
      unpinChart,
      updatePinnedChart,
      reorderCharts,
    }}>
      {children}
    </ChartContext.Provider>
  );
};

export const useChartState = () => {
  const context = useContext(ChartContext);
  if (!context) {
    throw new Error('useChartState must be used within ChartProvider');
  }
  return context;
};
```

