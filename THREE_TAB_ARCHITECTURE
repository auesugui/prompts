## 9. Deep Linking & Auto-Scroll

### useDeepLink Hook

```js
// src/hooks/useDeepLink.ts
import { useEffect, useRef, useCallback } from 'react';
import { useSearchParams, useLocation } from 'react-router-dom';

export const useDeepLink = () => {
  const [searchParams, setSearchParams] = useSearchParams();
  const location = useLocation();
  const answerRefs = useRef(new Map());

  const params: DeepLinkParams = {
    answerId: searchParams.get('answer'),
    tab: searchParams.get('tab') as TabValue | null,
  };

  // Register answer ref for scrolling
  const registerAnswerRef = useCallback((id, ref) => {
    if (ref) {
      answerRefs.current.set(id, ref);
    } else {
      answerRefs.current.delete(id);
    }
  }, []);

  // Scroll to target answer when params change
  useEffect(() => {
    if (params.answerId) {
      // Small delay to ensure DOM is ready
      const timer = setTimeout(() => {
        const element = answerRefs.current.get(params.answerId!);
        if (element) {
          element.scrollIntoView({ 
            behavior: 'smooth', 
            block: 'start' 
          });
          
          // Optional: Add highlight effect
          element.classList.add('highlight');
          setTimeout(() => element.classList.remove('highlight'), 2000);
        }
      }, 100);

      return () => clearTimeout(timer);
    }
  }, [params.answerId, location.pathname]);

  // Clear params after navigation (optional)
  const clearDeepLink = useCallback(() => {
    setSearchParams({});
  }, [setSearchParams]);

  return {
    ...params,
    registerAnswerRef,
    clearDeepLink,
  };
};
