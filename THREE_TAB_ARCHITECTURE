## Appendix A: Chart Type Transformation Utility

```javascript
// src/utils/chartTransforms.js

/**
 * Transform ECharts option from one chart type to another
 * @param {Object} currentOption - Current ECharts configuration
 * @param {string} newType - Target chart type (bar, line, pie, scatter, area)
 * @returns {Object} - Transformed ECharts configuration
 */
function transformChartType(currentOption, newType) {
  // Deep clone to avoid mutation
  var option = JSON.parse(JSON.stringify(currentOption));
  
  // Get existing series data
  var series = option.series && option.series[0];
  if (!series) return option;
  
  var data = series.data || [];
  
  switch (newType) {
    case 'bar':
      option.series = [{
        type: 'bar',
        data: data
      }];
      break;
      
    case 'line':
      option.series = [{
        type: 'line',
        data: data,
        smooth: true
      }];
      break;
      
    case 'area':
      option.series = [{
        type: 'line',
        data: data,
        smooth: true,
        areaStyle: {}
      }];
      break;
      
    case 'pie':
      // For pie, data needs name/value format
      var pieData = data.map(function(item, index) {
        if (typeof item === 'object' && item.name) {
          return item;
        }
        var name = option.xAxis && option.xAxis.data && option.xAxis.data[index];
        return {
          name: name || 'Item ' + (index + 1),
          value: typeof item === 'object' ? item.value : item
        };
      });
      
      option.series = [{
        type: 'pie',
        data: pieData,
        radius: '60%'
      }];
      // Remove axes for pie chart
      delete option.xAxis;
      delete option.yAxis;
      break;
      
    case 'scatter':
      option.series = [{
        type: 'scatter',
        data: data,
        symbolSize: 10
      }];
      break;
      
    default:
      break;
  }
  
  return option;
}

export { transformChartType };
```

