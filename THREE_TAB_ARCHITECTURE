// src/hooks/useCreateShareLink.ts
import { useCallback } from 'react';
import { useLocation } from 'react-router-dom';

export const useCreateShareLink = () => {
  const location = useLocation();

  return useCallback((
    threadId: string,
    answerId: string,
    tab?: TabValue
  ) => {
    const baseUrl = window.location.origin;
    const basePath = location.pathname.split('/chat')[0]; // Handle MFE base path
    
    const params = new URLSearchParams();
    params.set('answer', answerId);
    if (tab) {
      params.set('tab', tab);
    }

    return `${baseUrl}${basePath}/chat/${threadId}?${params.toString()}`;
  }, [location.pathname]);
};
