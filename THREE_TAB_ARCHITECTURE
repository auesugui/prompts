### Handling Parent Navigation

```js
// src/hooks/useParentNavigation.ts
import { useEffect } from 'react';
import { useNavigate, useLocation } from 'react-router-dom';

interface UseParentNavigationOptions {
  onNavigate?: (path: string) => void; // Callback to notify parent
}

export const useParentNavigation = (options?: UseParentNavigationOptions) => {
  const navigate = useNavigate();
  const location = useLocation();

  // Listen for navigation events from parent
  useEffect(() => {
    const handleParentNavigation = (event: CustomEvent<{ path: string }>) => {
      navigate(event.detail.path);
    };

    window.addEventListener(
      'insights:navigate' as any, 
      handleParentNavigation
    );

    return () => {
      window.removeEventListener(
        'insights:navigate' as any, 
        handleParentNavigation
      );
    };
  }, [navigate]);

  // Notify parent of internal navigation
  useEffect(() => {
    options?.onNavigate?.(location.pathname + location.search);
    
    // Dispatch event for parent to listen
    window.dispatchEvent(new CustomEvent('insights:location-change', {
      detail: { 
        path: location.pathname,
        search: location.search,
      }
    }));
  }, [location, options]);
};
