## 6. Three-Tab Answer Component

This is the core component that mimics WrenAI's Answer | SQL | Chart tabs.

### AnswerCard Component

```js
// src/components/AnswerCard/AnswerCard.js
import React, { forwardRef, useState, useEffect, useCallback } from 'react';
import { 
  Card, 
  TabNext as Tabs, 
  TabNextList as TabList, 
  TabNextTrigger as Tab, 
  TabNextPanel as TabPanel,
  Button,
  Tooltip,
} from '@salt-ds/core';
import { 
  CopyIcon, 
  PinIcon, 
  PinSolidIcon,
  ExpandIcon,
  ShareIcon,
} from '@salt-ds/icons';
import ReactECharts from 'echarts-for-react';
import ReactMarkdown from 'react-markdown';
import { Prism as SyntaxHighlighter } from 'react-syntax-highlighter';
import { vscDarkPlus } from 'react-syntax-highlighter/dist/esm/styles/prism';

import { useChartState } from '@/contexts/ChartContext';
import { useCreateShareLink } from '@/hooks/useCreateShareLink';
import { copyToClipboard } from '@/utils/clipboard';

import styles from './AnswerCard.module.scss';

export const AnswerCard = forwardRef(({
  id,
  threadId,
  question,
  answer,
  sql,
  chartOption,
  status,
  error,
  defaultTab = 'answer',
  onExpandChart,
}, ref) => {
  const [activeTab, setActiveTab] = useState(defaultTab);
  const { isPinned, pinChart, unpinChart } = useChartState();
  const createShareLink = useCreateShareLink();

  const chartIsPinned = isPinned(id);
  const hasChart = !!chartOption;

  // Sync tab with defaultTab prop (for deep linking)
  useEffect(() => {
    if (defaultTab) {
      setActiveTab(defaultTab);
    }
  }, [defaultTab]);

  const handleCopySQL = useCallback(() => {
    copyToClipboard(sql);
  }, [sql]);

  const handlePinToggle = useCallback(() => {
    if (chartIsPinned) {
      unpinChart(id);
    } else if (chartOption) {
      pinChart({
        threadId,
        messageId: id,
        question,
        sql,
        chartOption,
      });
    }
  }, [chartIsPinned, chartOption, id, threadId, question, sql, pinChart, unpinChart]);

  const handleShare = useCallback(() => {
    const link = createShareLink(threadId, id, activeTab);
    copyToClipboard(link);
  }, [createShareLink, threadId, id, activeTab]);

  if (status === 'loading') {
    return (
      <Card ref={ref} className={styles.card}>
        <div className={styles.loading}>
          <div className={styles.spinner} />
          <span>Analyzing your question...</span>
        </div>
      </Card>
    );
  }

  if (status === 'error') {
    return (
      <Card ref={ref} className={styles.card}>
        <div className={styles.error}>
          <span>Error: {error || 'Something went wrong'}</span>
        </div>
      </Card>
    );
  }

  return (
    <Card ref={ref} className={styles.card} id={`answer-${id}`}>
      {/* Question Reference */}
      <div className={styles.questionRef}>
        <span className={styles.questionLabel}>Q:</span>
        <span className={styles.questionText}>{question}</span>
      </div>

      {/* Tabs */}
      <Tabs value={activeTab} onChange={(_, val) => setActiveTab(val as TabValue)}>
        <div className={styles.tabHeader}>
          <TabList>
            <Tab value="answer">Answer</Tab>
            <Tab value="sql">SQL</Tab>
            <Tab value="chart" disabled={!hasChart}>
              Chart
            </Tab>
          </TabList>

          {/* Actions */}
          <div className={styles.actions}>
            <Tooltip content="Share link to this answer">
              <Button variant="secondary" onClick={handleShare}>
                <ShareIcon />
              </Button>
            </Tooltip>
            
            {activeTab === 'sql' && (
              <Tooltip content="Copy SQL">
                <Button variant="secondary" onClick={handleCopySQL}>
                  <CopyIcon />
                </Button>
              </Tooltip>
            )}
            
            {activeTab === 'chart' && hasChart && (
              <>
                <Tooltip content={chartIsPinned ? 'Unpin from dashboard' : 'Pin to dashboard'}>
                  <Button 
                    variant="secondary" 
                    onClick={handlePinToggle}
                    className={chartIsPinned ? styles.pinned : undefined}
                  >
                    {chartIsPinned ? <PinSolidIcon /> : <PinIcon />}
                  </Button>
                </Tooltip>
                
                <Tooltip content="Expand chart">
                  <Button variant="secondary" onClick={onExpandChart}>
                    <ExpandIcon />
                  </Button>
                </Tooltip>
              </>
            )}
          </div>
        </div>

        {/* Tab Panels */}
        <TabPanel value="answer" className={styles.tabPanel}>
          <div className={styles.answerContent}>
            <ReactMarkdown>{answer}</ReactMarkdown>
          </div>
        </TabPanel>

        <TabPanel value="sql" className={styles.tabPanel}>
          <div className={styles.sqlContent}>
            <SyntaxHighlighter 
              language="sql" 
              style={vscDarkPlus}
              customStyle={{ 
                margin: 0, 
                borderRadius: 'var(--salt-size-border-radius)',
              }}
            >
              {sql}
            </SyntaxHighlighter>
          </div>
        </TabPanel>

        <TabPanel value="chart" className={styles.tabPanel}>
          {hasChart && (
            <div className={styles.chartContent}>
              <ReactECharts
                option={chartOption}
                style={{ height: 400, width: '100%' }}
                opts={{ renderer: 'canvas' }}
              />
            </div>
          )}
        </TabPanel>
      </Tabs>
    </Card>
  );
});

AnswerCard.displayName = 'AnswerCard';
```

