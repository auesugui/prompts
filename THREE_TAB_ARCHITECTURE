// src/utils/navigation.js

/**
 * Create URL for navigating to a specific SQL item
 * @param {string} threadId 
 * @param {string} sqlId 
 * @returns {string}
 */
function createSqlUrl(threadId, sqlId) {
  return '/thread/' + threadId + '/sql/' + sqlId;
}

/**
 * Create URL for navigating to a specific chart item
 * @param {string} threadId 
 * @param {string} chartId 
 * @returns {string}
 */
function createChartUrl(threadId, chartId) {
  return '/thread/' + threadId + '/chart/' + chartId;
}

/**
 * Create URL for navigating to a specific message in Answer tab
 * @param {string} threadId 
 * @param {string} messageId 
 * @returns {string}
 */
function createAnswerUrl(threadId, messageId) {
  return '/thread/' + threadId + '?message=' + messageId;
}

/**
 * Create shareable link for external use
 * @param {string} threadId 
 * @param {string} tab - 'answer', 'sql', or 'chart'
 * @param {string} [itemId] - sqlId or chartId
 * @returns {string}
 */
function createShareableLink(threadId, tab, itemId) {
  var baseUrl = window.location.origin;
  var basePath = window.location.pathname.split('/thread')[0];
  
  var path = basePath + '/thread/' + threadId;
  if (tab !== 'answer') {
    path = path + '/' + tab;
    if (itemId) {
      path = path + '/' + itemId;
    }
  }
  
  return baseUrl + path;
}

export { createSqlUrl, createChartUrl, createAnswerUrl, createShareableLink };
```

### useAskQuestion Hook (Orchestrates All Three Tabs)

```javascript
// src/hooks/useAskQuestion.js
import { useCallback } from 'react';
import { useConversation } from '../contexts/ConversationContext';
import useInsightsApi from './useInsightsApi';

function useAskQuestion() {
  var conversation = useConversation();
  var addMessage = conversation.addMessage;
  var updateMessage = conversation.updateMessage;
  var addSqlItem = conversation.addSqlItem;
  var addChartItem = conversation.addChartItem;
  
  var api = useInsightsApi();

  var ask = useCallback(function(threadId, question) {
    // 1. Add user message
    addMessage(threadId, {
      role: 'user',
      content: question
    });

    // 2. Add placeholder assistant message
    var assistantMsgId = addMessage(threadId, {
      role: 'assistant',
      content: '',
      status: 'loading'
    });

    // 3. Call API
    api.askQuestion(question)
      .then(function(result) {
        // 4. Add SQL item
        var sqlId = addSqlItem(threadId, {
          messageId: assistantMsgId,
          question: question,
          query: result.sql
        });

        // 5. Generate chart
        return api.generateChart(question, result.sql)
          .then(function(chartResult) {
            // 6. Add chart item
            var chartId = null;
            if (chartResult && chartResult.chartOption) {
              chartId = addChartItem(threadId, {
                messageId: assistantMsgId,
                sqlId: sqlId,
                question: question,
                chartOption: chartResult.chartOption,
                chartType: chartResult.chartType || 'bar'
              });
            }

            // 7. Update assistant message with references
            updateMessage(threadId, assistantMsgId, {
              content: result.answer,
              status: 'success',
              sqlId: sqlId,
              chartId: chartId
            });
          });
      })
      .catch(function(error) {
        updateMessage(threadId, assistantMsgId, {
          status: 'error',
          error: error.message || 'Failed to process question'
        });
      });
  }, [addMessage, updateMessage, addSqlItem, addChartItem, api]);

  return ask;
}

export default useAskQuestion;
