```js
// src/views/DashboardView/DashboardView.js
import React, { useState, useCallback } from 'react';
import { useNavigate } from 'react-router-dom';
import { Card, Button, Text, H2 } from '@salt-ds/core';
import { DeleteIcon, EditIcon, MaximizeIcon } from '@salt-ds/icons';
import ReactECharts from 'echarts-for-react';

import { useChartState, PinnedChart } from '@/contexts/ChartContext';
import { ChartModal } from '@/components/ChartModal';

import styles from './DashboardView.module.scss';

export const DashboardView = () => {
  const navigate = useNavigate();
  const { pinnedCharts, unpinChart, updatePinnedChart } = useChartState();
  const [expandedChart, setExpandedChart] = useState<PinnedChart | null>(null);
  const [editingTitle, setEditingTitle] = useState<string | null>(null);

  const handleNavigateToSource = useCallback((chart) => {
    navigate(`/chat/${chart.threadId}?answer=${chart.messageId}&tab=chart`);
  }, [navigate]);

  const handleTitleSave = useCallback((chartId, newTitle) => {
    updatePinnedChart(chartId, { title: newTitle });
    setEditingTitle(null);
  }, [updatePinnedChart]);

  if (pinnedCharts.length === 0) {
    return (
      <div className={styles.emptyState}>
        <H2>No Pinned Charts</H2>
        <Text>
          Pin charts from your conversations to see them here.
          Click the pin icon on any chart to add it to your dashboard.
        </Text>
        <Button onClick={() => navigate('/chat')}>
          Start a Conversation
        </Button>
      </div>
    );
  }

  return (
    <div className={styles.dashboard}>
      <header className={styles.header}>
        <H2>Dashboard</H2>
        <Text color="secondary">{pinnedCharts.length} pinned charts</Text>
      </header>

      <div className={styles.grid}>
        {pinnedCharts.map(chart => (
          <Card key={chart.id} className={styles.chartCard}>
            {/* Header */}
            <div className={styles.cardHeader}>
              {editingTitle === chart.id ? (
                <input
                  autoFocus
                  defaultValue={chart.title || chart.question.slice(0, 50)}
                  onBlur={(e) => handleTitleSave(chart.id, e.target.value)}
                  onKeyDown={(e) => {
                    if (e.key === 'Enter') {
                      handleTitleSave(chart.id, e.currentTarget.value);
                    }
                    if (e.key === 'Escape') {
                      setEditingTitle(null);
                    }
                  }}
                  className={styles.titleInput}
                />
              ) : (
                <Text 
                  className={styles.cardTitle}
                  onClick={() => handleNavigateToSource(chart)}
                >
                  {chart.title || chart.question.slice(0, 50)}
                </Text>
              )}
              
              <div className={styles.cardActions}>
                <Button 
                  variant="secondary" 
                  onClick={() => setEditingTitle(chart.id)}
                >
                  <EditIcon size={1} />
                </Button>
                <Button 
                  variant="secondary" 
                  onClick={() => setExpandedChart(chart)}
                >
                  <MaximizeIcon size={1} />
                </Button>
                <Button 
                  variant="secondary" 
                  onClick={() => unpinChart(chart.id)}
                >
                  <DeleteIcon size={1} />
                </Button>
              </div>
            </div>

            {/* Chart */}
            <div className={styles.chartContainer}>
              <ReactECharts
                option={chart.chartOption}
                style={{ height: '100%', width: '100%' }}
                opts={{ renderer: 'canvas' }}
              />
            </div>

            {/* Footer */}
            <div className={styles.cardFooter}>
              <Text color="secondary" styleAs="label">
                Pinned {new Date(chart.pinnedAt).toLocaleDateString()}
              </Text>
            </div>
          </Card>
        ))}
      </div>

      {/* Expanded Chart Modal */}
      {expandedChart && (
        <ChartModal
          chart={expandedChart}
          onClose={() => setExpandedChart(null)}
          onNavigateToSource={() => handleNavigateToSource(expandedChart)}
        />
      )}
    </div>
  );
};
