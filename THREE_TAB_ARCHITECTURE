```js
// src/views/ChatView/ChatView.js
import React, { useCallback } from 'react';
import { useParams } from 'react-router-dom';

import { useConversation } from '@/contexts/ConversationContext';
import { useDeepLink } from '@/hooks/useDeepLink';
import { useAskWithChart } from '@/hooks/useAskWithChart';

import { MessageList } from '@/components/MessageList';
import { QuestionInput } from '@/components/QuestionInput';
import { EmptyState } from '@/components/EmptyState';

import styles from './ChatView.module.scss';

export const ChatView = () => {
  const { threadId } = useParams<{ threadId?: string }>();
  const { threads, activeThread, selectThread, createThread } = useConversation();
  const { answerId, tab, registerAnswerRef } = useDeepLink();
  const { ask } = useAskWithChart();

  // Sync URL threadId with context
  React.useEffect(() => {
    if (threadId && threadId !== activeThread?.id) {
      selectThread(threadId);
    }
  }, [threadId, activeThread?.id, selectThread]);

  const handleSubmit = useCallback((question: string) => {
    ask(question);
  }, [ask]);

  // No thread selected - show empty state
  if (!activeThread) {
    return (
      <div className={styles.chatView}>
        <EmptyState onNewChat={createThread} />
        <QuestionInput onSubmit={handleSubmit} />
      </div>
    );
  }

  return (
    <div className={styles.chatView}>
      <MessageList
        messages={activeThread.messages}
        threadId={activeThread.id}
        targetAnswerId={answerId}
        targetTab={tab}
        registerRef={registerAnswerRef}
      />
      <QuestionInput onSubmit={handleSubmit} />
    </div>
  );
};
