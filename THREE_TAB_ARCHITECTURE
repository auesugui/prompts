## 7. Chart State Management

### useInsightsAPI Hook

```js
// src/hooks/useInsightsAPI.ts
import { useState, useCallback } from 'react';
import axios from 'axios';
import type { EChartsOption } from 'echarts';

const API_BASE = import.meta.env.VITE_API_BASE || '/api/insights';
const POLL_INTERVAL = 1000; // 1 second
const MAX_POLLS = 120; // 2 minutes max

export const useInsightsAPI = () => {
  const [isLoading, setIsLoading] = useState(false);

  const askQuestion = useCallback(async (
    question: string,
    onStatusChange?: (status: string) => void
  ): Promise<{ answer: string; sql: string } | null> => {
    setIsLoading(true);

    try {
      // 1. Start the task
      const { data: { taskId } } = await axios.post<AskResponse>(
        `${API_BASE}/ask`,
        { query: question }
      );

      // 2. Poll for completion
      let polls = 0;
      while (polls < MAX_POLLS) {
        const { data: status } = await axios.get<TaskStatus>(
          `${API_BASE}/ask/${taskId}`
        );

        onStatusChange?.(status.status);

        if (status.status === 'finished') {
          return {
            answer: status.answer || '',
            sql: status.sql || '',
          };
        }

        if (status.status === 'failed') {
          throw new Error(status.error || 'Query failed');
        }

        await new Promise(resolve => setTimeout(resolve, POLL_INTERVAL));
        polls++;
      }

      throw new Error('Query timed out');
    } finally {
      setIsLoading(false);
    }
  }, []);

  const generateChart = useCallback(async (
    question: string,
    sql: string,
    customInstruction?: string
  ): Promise<EChartsOption | null> => {
    try {
      const { data } = await axios.post<ChartResponse>(
        `${API_BASE}/chart`,
        { question, sql, customInstruction }
      );
      return data.chartOption;
    } catch (error) {
      console.error('Chart generation failed:', error);
      return null;
    }
  }, []);

  return {
    isLoading,
    askQuestion,
    generateChart,
  };
};
```

### useAskWithChart Hook (Combined Flow)

```js
// src/hooks/useAskWithChart.ts
import { useCallback } from 'react';
import { useConversation } from '@/contexts/ConversationContext';
import { useInsightsAPI } from './useInsightsAPI';

export const useAskWithChart = () => {
  const { addMessage, updateMessage, activeThreadId, createThread } = useConversation();
  const { askQuestion, generateChart } = useInsightsAPI();

  const ask = useCallback(async (question: string) => {
    // Ensure we have a thread
    const threadId = activeThreadId || createThread();

    // 1. Add user message
    addMessage(threadId, {
      role: 'user',
      content: question,
    });

    // 2. Add placeholder assistant message
    const assistantMsgId = addMessage(threadId, {
      role: 'assistant',
      content: '',
      status: 'loading',
    });

    try {
      // 3. Get answer and SQL
      const result = await askQuestion(question, (status) => {
        // Optional: Update loading state with status text
        updateMessage(threadId, assistantMsgId, {
          content: `${status}...`,
        });
      });

      if (!result) {
        throw new Error('No result returned');
      }

      // 4. Update with answer and SQL
      updateMessage(threadId, assistantMsgId, {
        content: result.answer,
        sql: result.sql,
        status: 'success',
      });

      // 5. Generate chart (async, don't block)
      generateChart(question, result.sql).then(chartOption => {
        if (chartOption) {
          updateMessage(threadId, assistantMsgId, {
            chartOption,
            chartId: assistantMsgId, // Use message ID as chart ID
          });
        }
      });

    } catch (error) {
      updateMessage(threadId, assistantMsgId, {
        status: 'error',
        error: error instanceof Error ? error.message : 'Unknown error',
      });
    }
  }, [activeThreadId, createThread, addMessage, updateMessage, askQuestion, generateChart]);

  return { ask };
};
