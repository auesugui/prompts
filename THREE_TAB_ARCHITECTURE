## 5. State Management

### Data Structures

```javascript
// src/types/conversation.js

/**
 * @typedef {Object} Message
 * @property {string} id - Unique message ID
 * @property {'user'|'assistant'} role - Message sender
 * @property {string} content - Message content
 * @property {Date} timestamp - When message was created
 * @property {string} [sqlId] - Reference to SQL item (assistant only)
 * @property {string} [chartId] - Reference to Chart item (assistant only)
 * @property {'loading'|'success'|'error'} [status] - Processing status
 * @property {string} [error] - Error message if failed
 */

/**
 * @typedef {Object} SqlItem
 * @property {string} id - Unique SQL ID
 * @property {string} messageId - Reference to parent message
 * @property {string} threadId - Reference to thread
 * @property {string} question - Original question that generated this SQL
 * @property {string} query - The SQL query
 * @property {Array} [results] - Query results if executed
 * @property {Date} createdAt - When SQL was generated
 */

/**
 * @typedef {Object} ChartItem
 * @property {string} id - Unique chart ID
 * @property {string} messageId - Reference to parent message
 * @property {string} sqlId - Reference to source SQL
 * @property {string} threadId - Reference to thread
 * @property {string} question - Original question
 * @property {Object} chartOption - ECharts configuration
 * @property {string} chartType - Current chart type (bar, line, pie, etc.)
 * @property {boolean} isPinned - Whether pinned to dashboard
 * @property {Date} createdAt - When chart was generated
 */

/**
 * @typedef {Object} Thread
 * @property {string} id - Unique thread ID
 * @property {string} title - Thread title (from first question)
 * @property {Message[]} messages - All messages in thread
 * @property {SqlItem[]} sqlItems - All SQL items in thread
 * @property {ChartItem[]} chartItems - All chart items in thread
 * @property {Date} createdAt
 * @property {Date} updatedAt
 */
```

### Conversation Context

```javascript
// src/contexts/ConversationContext.js
import { createContext, useContext, useCallback, useMemo } from 'react';
import useLocalStorageState from '../hooks/useLocalStorageState';

const ConversationContext = createContext(null);

function generateId() {
  return crypto.randomUUID();
}

function ConversationProvider({ children }) {
  const [threads, setThreads] = useLocalStorageState('insights-threads', []);
  const [activeThreadId, setActiveThreadId] = useLocalStorageState(
    'insights-active-thread',
    null
  );

  // Computed: active thread
  const activeThread = useMemo(
    function() {
      return threads.find(function(t) { return t.id === activeThreadId; }) || null;
    },
    [threads, activeThreadId]
  );

  // Create new thread
  const createThread = useCallback(function() {
    var newThread = {
      id: generateId(),
      title: 'New Conversation',
      messages: [],
      sqlItems: [],
      chartItems: [],
      createdAt: new Date(),
      updatedAt: new Date()
    };
    
    setThreads(function(prev) { return [newThread].concat(prev); });
    setActiveThreadId(newThread.id);
    return newThread.id;
  }, [setThreads, setActiveThreadId]);

  // Select thread
  const selectThread = useCallback(function(threadId) {
    setActiveThreadId(threadId);
  }, [setActiveThreadId]);

  // Delete thread
  const deleteThread = useCallback(function(threadId) {
    setThreads(function(prev) {
      return prev.filter(function(t) { return t.id !== threadId; });
    });
    if (activeThreadId === threadId) {
      setActiveThreadId(null);
    }
  }, [setThreads, activeThreadId, setActiveThreadId]);

  // Add message to thread
  const addMessage = useCallback(function(threadId, message) {
    var messageId = generateId();
    var newMessage = Object.assign({}, message, {
      id: messageId,
      timestamp: new Date()
    });

    setThreads(function(prev) {
      return prev.map(function(thread) {
        if (thread.id !== threadId) return thread;
        
        // Update title from first user message
        var title = thread.messages.length === 0 && message.role === 'user'
          ? message.content.slice(0, 50) + (message.content.length > 50 ? '...' : '')
          : thread.title;

        return Object.assign({}, thread, {
          title: title,
          messages: thread.messages.concat([newMessage]),
          updatedAt: new Date()
        });
      });
    });

    return messageId;
  }, [setThreads]);

  // Update message
  const updateMessage = useCallback(function(threadId, messageId, updates) {
    setThreads(function(prev) {
      return prev.map(function(thread) {
        if (thread.id !== threadId) return thread;
        return Object.assign({}, thread, {
          messages: thread.messages.map(function(msg) {
            return msg.id === messageId ? Object.assign({}, msg, updates) : msg;
          }),
          updatedAt: new Date()
        });
      });
    });
  }, [setThreads]);

  // Add SQL item
  const addSqlItem = useCallback(function(threadId, sqlItem) {
    var sqlId = generateId();
    var newSqlItem = Object.assign({}, sqlItem, {
      id: sqlId,
      threadId: threadId,
      createdAt: new Date()
    });

    setThreads(function(prev) {
      return prev.map(function(thread) {
        if (thread.id !== threadId) return thread;
        return Object.assign({}, thread, {
          sqlItems: thread.sqlItems.concat([newSqlItem]),
          updatedAt: new Date()
        });
      });
    });

    return sqlId;
  }, [setThreads]);

  // Add chart item
  const addChartItem = useCallback(function(threadId, chartItem) {
    var chartId = generateId();
    var newChartItem = Object.assign({}, chartItem, {
      id: chartId,
      threadId: threadId,
      isPinned: false,
      createdAt: new Date()
    });

    setThreads(function(prev) {
      return prev.map(function(thread) {
        if (thread.id !== threadId) return thread;
        return Object.assign({}, thread, {
          chartItems: thread.chartItems.concat([newChartItem]),
          updatedAt: new Date()
        });
      });
    });

    return chartId;
  }, [setThreads]);

  // Update chart item (for type change, refresh, pin)
  const updateChartItem = useCallback(function(threadId, chartId, updates) {
    setThreads(function(prev) {
      return prev.map(function(thread) {
        if (thread.id !== threadId) return thread;
        return Object.assign({}, thread, {
          chartItems: thread.chartItems.map(function(chart) {
            return chart.id === chartId ? Object.assign({}, chart, updates) : chart;
          }),
          updatedAt: new Date()
        });
      });
    });
  }, [setThreads]);

  // Get all pinned charts across all threads
  const getPinnedCharts = useCallback(function() {
    var pinned = [];
    threads.forEach(function(thread) {
      thread.chartItems.forEach(function(chart) {
        if (chart.isPinned) {
          pinned.push(Object.assign({}, chart, { threadTitle: thread.title }));
        }
      });
    });
    return pinned;
  }, [threads]);

  var value = {
    threads: threads,
    activeThreadId: activeThreadId,
    activeThread: activeThread,
    createThread: createThread,
    selectThread: selectThread,
    deleteThread: deleteThread,
    addMessage: addMessage,
    updateMessage: updateMessage,
    addSqlItem: addSqlItem,
    addChartItem: addChartItem,
    updateChartItem: updateChartItem,
    getPinnedCharts: getPinnedCharts
  };

  return (
    <ConversationContext.Provider value={value}>
      {children}
    </ConversationContext.Provider>
  );
}

function useConversation() {
  var context = useContext(ConversationContext);
  if (!context) {
    throw new Error('useConversation must be used within ConversationProvider');
  }
  return context;
}

export { ConversationProvider, useConversation };
export default ConversationContext;
```

